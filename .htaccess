# ============================================================
# MdS Websites — clean URLs + 301 redirects
# Hostinger (LiteSpeed/Apache) — mod_rewrite
# ============================================================

# Don't expose directory listings
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ----------------------------------------------------------
  # 1) 301 redirects for old indexed URLs -> current pages
  #    (from Google site:mdswebsites.co.uk)
  # ----------------------------------------------------------
  RewriteRule ^contact-us/?$                    /contact                  [R=301,L,NC]
  RewriteRule ^our-work-todate/?$               /portfolio                [R=301,L,NC]
  RewriteRule ^portfolio/transport-elevated/?$  /project-swift-robin      [R=301,L,NC]
  RewriteRule ^portfolio/clover-coaching/?$     /project-clover-coaching  [R=301,L,NC]
  # Catch-all for any other old /portfolio/<slug> -> portfolio index
  RewriteRule ^portfolio/.+                     /portfolio                [R=301,L,NC]

  # ----------------------------------------------------------
  #  Insights migrated to CMS-generated /insights/<slug>
  # ----------------------------------------------------------
  RewriteRule ^insight-website-speed/?$         /insights/website-speed       [R=301,L,NC]
  RewriteRule ^insight-near-me-searches/?$      /insights/near-me-searches    [R=301,L,NC]
  RewriteRule ^insight-website-conversion/?$    /insights/website-conversion  [R=301,L,NC]
  RewriteRule ^insight-refresh-or-rebrand/?$    /insights/refresh-or-rebrand  [R=301,L,NC]
  RewriteRule ^insight-direct-bookings/?$       /insights/direct-bookings     [R=301,L,NC]
  RewriteRule ^insight-competitor-reviews/?$    /insights/competitor-reviews  [R=301,L,NC]
  # Old /blog section now lives at /insights
  RewriteRule ^blog/?$                          /insights                     [R=301,L,NC]
  RewriteRule ^blog/(.+)$                       /insights/$1                  [R=301,L,NC]

  # ----------------------------------------------------------
  # 2) Canonicalise the home page (/index, /index.html -> /)
  # ----------------------------------------------------------
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # ----------------------------------------------------------
  # 3) Redirect any *.html request to its clean URL (one time)
  # ----------------------------------------------------------
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # ----------------------------------------------------------
  # 4) Internally serve the .html file for a clean URL request
  # ----------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ============================================================
# Performance: compression + browser caching
# ============================================================

# --- Gzip/deflate text assets ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/x-javascript application/json \
    image/svg+xml application/xml application/rss+xml
</IfModule>

# --- Browser caching ---
<IfModule mod_expires.c>
  ExpiresActive On
  # Images & fonts: cache 1 year (filenames are versioned with ?v=)
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  # CSS & JS: cache 1 year (versioned with ?v=)
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  # HTML: revalidate frequently so content updates show quickly
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>
