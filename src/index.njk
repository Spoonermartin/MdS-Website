---
title: "Insights"
description: "Practical thinking on branding, websites, SEO and winning more local customers — written for business owners, not marketers."
permalink: "/index.html"
---
{% extends "base.njk" %}

{% block content %}
<section class="page-hero" style="position:relative;overflow:hidden;">
  <canvas id="hero-dots" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;"></canvas>
  <div class="container" style="position:relative;z-index:1;">
    <p class="crumbs"><a href="/">Home</a> / Insights</p>
    <p class="eyebrow">Insights</p>
    <h1>Growth advice without the jargon.</h1>
    <p class="lead">Practical thinking on branding, websites, SEO and winning more local customers — written for business owners, not marketers.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid grid-3">
      {% for post in collections.posts | reverse %}
      <article class="card post-card">
        <div class="meta"><span class="tag tag--gold">{{ post.data.tag }}</span>{% if post.data.readtime %}<span>{{ post.data.readtime }}</span>{% endif %}</div>
        <h3><a href="/insights{{ post.url }}">{{ post.data.title }}</a></h3>
        <p class="muted mt-2">{{ post.data.description }}</p>
        <a class="text-link card-link" href="/insights{{ post.url }}" style="margin-top:auto;">Read article</a>
        <div class="meta" style="margin-top:1.1rem;margin-bottom:0;"><span>{{ site.author }}</span><span>·</span><span><time datetime="{{ post.date.toISOString().slice(0,10) }}">{{ post.date | readableDate }}</time></span></div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
